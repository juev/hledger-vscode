{
  "name": "hledger",
  "displayName": "hledger Language Support",
  "description": "Full-featured hledger extension with syntax highlighting, intelligent code completion, amount alignment, and project-based caching for journal files",
  "version": "0.4.0",
  "publisher": "evsyukov",
  "engines": {
    "vscode": "^1.110.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Language Packs",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "hledger",
    "accounting",
    "finance",
    "ledger",
    "intellisense",
    "autocomplete",
    "plain text accounting"
  ],
  "main": "./out/extension/main.js",
  "contributes": {
    "languages": [
      {
        "id": "hledger",
        "aliases": [
          "hledger",
          "HLedger"
        ],
        "extensions": [
          ".journal",
          ".hledger",
          ".ledger"
        ],
        "filenames": [
          "journal",
          ".journal"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "hledger-rules",
        "aliases": [
          "HLedger Rules",
          "hledger-rules"
        ],
        "extensions": [
          ".rules"
        ],
        "configuration": "./language-configuration-rules.json"
      }
    ],
    "grammars": [
      {
        "language": "hledger",
        "scopeName": "source.hledger",
        "path": "./syntaxes/hledger.tmLanguage.json"
      },
      {
        "language": "hledger-rules",
        "scopeName": "source.hledger-rules",
        "path": "./syntaxes/hledger-rules.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "HLedger",
      "properties": {
        "hledger.autoCompletion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic completion without keyboard shortcuts (Ctrl+Space)",
          "deprecationMessage": "Use hledger.features.completion instead."
        },
        "hledger.autoCompletion.maxResults": {
          "type": "number",
          "default": 25,
          "minimum": 5,
          "maximum": 50,
          "description": "Maximum number of completion items to show",
          "deprecationMessage": "Use hledger.completion.maxResults instead."
        },
        "hledger.autoCompletion.maxAccountResults": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 50,
          "description": "Maximum number of account completion items to show (accounts are hierarchical, so more items are useful)",
          "deprecationMessage": "This setting is no longer used by the LSP server."
        },
        "hledger.cli.path": {
          "type": "string",
          "default": "",
          "description": "Path to hledger executable. If empty, will search in system PATH"
        },
        "hledger.cli.journalFile": {
          "type": "string",
          "default": "",
          "description": "Path to the main hledger journal file. If empty, will try to use LEDGER_FILE environment variable or current file"
        },
        "hledger.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics validation for hledger files (account checks, tag format, amount format)",
          "deprecationMessage": "Use hledger.features.diagnostics instead."
        },
        "hledger.diagnostics.checkBalance": {
          "type": "boolean",
          "default": true,
          "description": "Check that transactions balance correctly (all postings sum to zero per commodity)",
          "deprecationMessage": "Use hledger.diagnostics.unbalancedTransactions instead."
        },
        "hledger.diagnostics.balanceTolerance": {
          "type": "number",
          "default": 1e-10,
          "minimum": 0,
          "description": "Tolerance for balance validation (default: 1e-10). Increase for high-precision cryptocurrencies (e.g., 1e-8 for Bitcoin)."
        },
        "hledger.formatting.amountAlignmentColumn": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 120,
          "description": "Fixed mode-specific amount alignment target (0 = auto, preserves hand-formatted layout). In left mode this is the amount start column; in right mode this is the amount end column; in decimal mode this is the decimal-point column."
        },
        "hledger.autoCompletion.transactionTemplates.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable transaction template completion. When typing a payee name, suggests complete transactions with accounts and amounts based on history.",
          "deprecationMessage": "This setting is no longer used by the LSP server."
        },
        "hledger.import.defaultDebitAccount": {
          "type": "string",
          "default": "expenses:unknown",
          "description": "Default account name for debit (expense) entries when importing CSV/TSV"
        },
        "hledger.import.defaultCreditAccount": {
          "type": "string",
          "default": "income:unknown",
          "description": "Default account name for credit (income) entries when importing CSV/TSV"
        },
        "hledger.import.defaultBalancingAccount": {
          "type": "string",
          "default": "TODO:account",
          "description": "Default account name for balancing posting when importing CSV/TSV"
        },
        "hledger.import.dateFormat": {
          "type": "string",
          "enum": [
            "auto",
            "YYYY-MM-DD",
            "YYYY/MM/DD",
            "DD/MM/YYYY",
            "MM/DD/YYYY",
            "DD.MM.YYYY",
            "DD-MM-YYYY"
          ],
          "default": "auto",
          "description": "Expected date format in import data. Use 'auto' for automatic detection"
        },
        "hledger.import.invertAmounts": {
          "type": "boolean",
          "default": false,
          "description": "Invert amount signs when importing (useful for some bank exports)"
        },
        "hledger.import.useJournalHistory": {
          "type": "boolean",
          "default": true,
          "description": "Use existing journal transactions to auto-detect accounts for similar payees"
        },
        "hledger.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to hledger-lsp executable. If empty, will use auto-downloaded binary or search in system PATH"
        },
        "hledger.lsp.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for the LSP server"
        },
        "hledger.lsp.checkForUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Check for Language Server updates on extension activation"
        },
        "hledger.features.hover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover information from the Language Server"
        },
        "hledger.features.completion": {
          "type": "boolean",
          "default": true,
          "description": "Enable autocompletion from the Language Server"
        },
        "hledger.features.formatting": {
          "type": "boolean",
          "default": true,
          "description": "Enable document formatting from the Language Server"
        },
        "hledger.features.diagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics from the Language Server"
        },
        "hledger.features.semanticTokens": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic tokens from the Language Server"
        },
        "hledger.features.codeActions": {
          "type": "boolean",
          "default": true,
          "description": "Enable code actions from the Language Server"
        },
        "hledger.features.foldingRanges": {
          "type": "boolean",
          "default": true,
          "description": "Enable folding ranges for transactions from the Language Server"
        },
        "hledger.features.documentLinks": {
          "type": "boolean",
          "default": true,
          "description": "Enable document links for include directives from the Language Server"
        },
        "hledger.features.workspaceSymbol": {
          "type": "boolean",
          "default": true,
          "description": "Enable workspace symbol search from the Language Server"
        },
        "hledger.features.inlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline ghost text completions from the Language Server"
        },
        "hledger.features.codeLens": {
          "type": "boolean",
          "default": false,
          "description": "Enable balance check indicators on transactions (CodeLens)"
        },
        "hledger.completion.snippets": {
          "type": "boolean",
          "default": true,
          "description": "Enable snippet completions for payees"
        },
        "hledger.completion.fuzzyMatching": {
          "type": "boolean",
          "default": true,
          "description": "Enable fuzzy matching for completions"
        },
        "hledger.completion.showCounts": {
          "type": "boolean",
          "default": true,
          "description": "Show usage counts in completion items"
        },
        "hledger.completion.maxResults": {
          "type": "number",
          "default": 50,
          "minimum": 5,
          "maximum": 200,
          "description": "Maximum number of completion items from the Language Server"
        },
        "hledger.completion.includeNotes": {
          "type": "boolean",
          "default": true,
          "description": "Include notes in payee completions from the Language Server"
        },
        "hledger.diagnostics.undeclaredAccounts": {
          "type": "boolean",
          "default": true,
          "description": "Report undeclared accounts as warnings"
        },
        "hledger.diagnostics.undeclaredCommodities": {
          "type": "boolean",
          "default": true,
          "description": "Report undeclared commodities as warnings"
        },
        "hledger.diagnostics.unbalancedTransactions": {
          "type": "boolean",
          "default": true,
          "description": "Report unbalanced transactions as errors"
        },
        "hledger.formatting.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 2,
          "maximum": 8,
          "description": "Number of spaces for posting indentation"
        },
        "hledger.formatting.alignAmounts": {
          "type": "boolean",
          "default": true,
          "description": "Align amounts in postings"
        },
        "hledger.formatting.amountAlignmentMode": {
          "type": "string",
          "enum": [
            "left",
            "right",
            "decimal"
          ],
          "default": "right",
          "description": "Amount alignment mode. 'left' aligns amount starts. 'right' aligns amounts by their right edge (default). 'decimal' aligns amounts by the decimal point (mantissa alignment)."
        },
        "hledger.cli.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable CLI integration for hledger commands"
        },
        "hledger.cli.timeout": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Timeout for CLI commands in milliseconds"
        },
        "hledger.limits.maxFileSizeBytes": {
          "type": "number",
          "default": 10485760,
          "minimum": 1048576,
          "maximum": 104857600,
          "description": "Maximum file size to process in bytes (default: 10MB)"
        },
        "hledger.limits.maxIncludeDepth": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum depth for include directive resolution"
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "hledger-rules",
        "scopes": {
          "comment": [
            "comment.line"
          ],
          "string": [
            "string.quoted"
          ],
          "keyword": [
            "keyword.control"
          ],
          "regexp": [
            "string.regexp"
          ],
          "parameter": [
            "variable.parameter"
          ]
        }
      },
      {
        "language": "hledger",
        "scopes": {
          "namespace": [
            "entity.name.namespace"
          ],
          "type": [
            "entity.name.type"
          ],
          "function": [
            "entity.name.function"
          ],
          "number": [
            "constant.numeric"
          ],
          "decorator": [
            "entity.name.tag"
          ],
          "keyword": [
            "keyword.control"
          ],
          "string": [
            "string.quoted"
          ],
          "operator": [
            "keyword.operator"
          ],
          "comment": [
            "comment.line"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "hledger.cli.balance",
        "title": "HLedger: Insert Balance Report",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.cli.stats",
        "title": "HLedger: Insert Statistics Report",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.cli.incomestatement",
        "title": "HLedger: Insert Income Statement",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.import.fromSelection",
        "title": "HLedger: Import Selected Tabular Data",
        "category": "HLedger"
      },
      {
        "command": "hledger.import.fromFile",
        "title": "HLedger: Import Tabular Data from File",
        "category": "HLedger"
      },
      {
        "command": "hledger.lsp.update",
        "title": "HLedger: Install/Update Language Server",
        "category": "HLedger"
      },
      {
        "command": "hledger.lsp.showVersion",
        "title": "HLedger: Show Language Server Version",
        "category": "HLedger"
      },
      {
        "command": "hledger.lsp.restart",
        "title": "HLedger: Restart Language Server",
        "category": "HLedger"
      },
      {
        "command": "hledger.editor.alignAmount",
        "title": "HLedger: Align Amount to Column",
        "category": "HLedger"
      },
      {
        "command": "hledger.editor.enterAndSuggest",
        "title": "HLedger: Enter and Suggest Inline Completion",
        "category": "HLedger"
      },
      {
        "command": "hledger.getStarted",
        "title": "HLedger: Get Started",
        "category": "HLedger"
      },
      {
        "command": "hledger.editor.cycleStatus",
        "title": "HLedger: Cycle Transaction/Posting Status",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.editor.setStatusUnmarked",
        "title": "HLedger: Set Status to Unmarked",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.editor.setStatusPending",
        "title": "HLedger: Set Status to Pending (!)",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.editor.setStatusCleared",
        "title": "HLedger: Set Status to Cleared (*)",
        "category": "HLedger",
        "when": "editorTextFocus && editorLangId == hledger"
      }
    ],
    "keybindings": [
      {
        "command": "acceptSelectedSuggestion",
        "key": "enter",
        "when": "editorTextFocus && editorLangId == hledger && suggestWidgetVisible"
      },
      {
        "command": "editor.action.inlineSuggest.commit",
        "key": "enter",
        "when": "editorTextFocus && editorLangId == hledger && inlineSuggestionVisible"
      },
      {
        "command": "hledger.editor.enterAndSuggest",
        "key": "enter",
        "when": "editorTextFocus && editorLangId == hledger && !suggestWidgetVisible && !inlineSuggestionVisible && !inSnippetMode"
      },
      {
        "command": "hledger.editor.alignAmount",
        "key": "tab",
        "when": "editorTextFocus && editorLangId == hledger && !suggestWidgetVisible && !inlineSuggestionVisible && !inSnippetMode && !hasSnippetCompletions"
      },
      {
        "command": "hledger.editor.cycleStatus",
        "key": "cmd+k s",
        "mac": "cmd+k s",
        "win": "ctrl+k s",
        "linux": "ctrl+k s",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.editor.setStatusUnmarked",
        "key": "cmd+k 0",
        "mac": "cmd+k 0",
        "win": "ctrl+k 0",
        "linux": "ctrl+k 0",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.editor.setStatusPending",
        "key": "cmd+k 1",
        "mac": "cmd+k 1",
        "win": "ctrl+k 1",
        "linux": "ctrl+k 1",
        "when": "editorTextFocus && editorLangId == hledger"
      },
      {
        "command": "hledger.editor.setStatusCleared",
        "key": "cmd+k 2",
        "mac": "cmd+k 2",
        "win": "ctrl+k 2",
        "linux": "ctrl+k 2",
        "when": "editorTextFocus && editorLangId == hledger"
      }
    ],
    "configurationDefaults": {
      "[hledger]": {
        "editor.formatOnType": true
      },
      "files.associations": {
        "*.journal": "hledger",
        "*.hledger": "hledger",
        "*.ledger": "hledger",
        "journal": "hledger",
        "*.rules": "hledger-rules"
      }
    },
    "submenus": [
      {
        "id": "hledger.submenu",
        "label": "HLedger"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "hledger.submenu",
          "group": "navigation",
          "when": "editorLangId == hledger"
        }
      ],
      "hledger.submenu": [
        {
          "command": "hledger.cli.balance",
          "group": "1_reports@1"
        },
        {
          "command": "hledger.cli.incomestatement",
          "group": "1_reports@2"
        },
        {
          "command": "hledger.cli.stats",
          "group": "1_reports@3"
        }
      ],
      "commandPalette": [
        {
          "command": "hledger.cli.balance",
          "when": "editorLangId == hledger"
        },
        {
          "command": "hledger.cli.stats",
          "when": "editorLangId == hledger"
        },
        {
          "command": "hledger.cli.incomestatement",
          "when": "editorLangId == hledger"
        },
        {
          "command": "hledger.editor.alignAmount",
          "when": "editorLangId == hledger"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "hledger.getStarted",
        "title": "Get Started with HLedger",
        "description": "Set up the HLedger extension for plain text accounting in VS Code.",
        "steps": [
          {
            "id": "hledger.installLSP",
            "title": "Install Language Server",
            "description": "You will be **prompted to install** the Language Server when you first open a journal file. Use the button below to manually reinstall or update.\n\n[Install/Update Language Server](command:hledger.lsp.update)",
            "media": {
              "markdown": "docs/walkthrough/install-lsp.md"
            },
            "completionEvents": [
              "onCommand:hledger.lsp.update"
            ]
          },
          {
            "id": "hledger.openJournal",
            "title": "Open a Journal File",
            "description": "Open a `.journal`, `.hledger`, or `.ledger` file to see syntax highlighting, completion, and diagnostics in action.",
            "media": {
              "markdown": "docs/walkthrough/open-journal.md"
            },
            "completionEvents": [
              "onLanguage:hledger"
            ]
          },
          {
            "id": "hledger.importCSV",
            "title": "Import from CSV",
            "description": "Import transactions from CSV/TSV files into hledger format.\n\n[Import from File](command:hledger.import.fromFile)",
            "media": {
              "markdown": "docs/walkthrough/import-csv.md"
            },
            "completionEvents": [
              "onCommand:hledger.import.fromFile",
              "onCommand:hledger.import.fromSelection"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild:prod",
    "compile": "tsc -p ./tsconfig.dev.json",
    "compile:prod": "tsc -p ./",
    "esbuild": "node esbuild.js",
    "esbuild:prod": "node esbuild.js --production",
    "esbuild:watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p ./",
    "watch": "npm run esbuild:watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored --max-warnings=0",
    "lint:fix": "eslint src/**/*.ts --fix --no-warn-ignored",
    "clean": "rimraf out *.vsix",
    "prebuild": "npm run clean",
    "build": "npm run esbuild:prod",
    "prepackage": "npm run clean",
    "package": "npm run esbuild:prod && vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "25.x",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "ovsx": "^0.10.11",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juev/hledger-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/juev/hledger-vscode/issues"
  },
  "homepage": "https://github.com/juev/hledger-vscode#readme",
  "icon": "images/icon.png",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
